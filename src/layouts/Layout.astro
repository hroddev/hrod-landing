---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Inicia tu carrera en Infraestructura, Linux y DevOps." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="relative min-h-screen">
		<!-- Malla base -->
		<div class="pointer-events-none fixed inset-0 z-[-2] tech-grid-bg opacity-30"></div>
		
		<!-- Nord Aurora Ambient Blobs para un toque moderno y joven -->
		<div class="pointer-events-none fixed inset-0 z-[-1] overflow-hidden">
			<!-- Púrpura (nord15) arriba a la izquierda -->
			<div class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] rounded-full bg-nord15 opacity-[0.12] blur-[120px]"></div>
			<!-- Rojo (nord11) arriba a la derecha (Énfasis nuevo) -->
			<div class="absolute -top-[5%] -right-[5%] w-[30%] h-[30%] rounded-full bg-nord11 opacity-[0.10] blur-[120px]"></div>
			<!-- Verde (nord14) al centro derecha -->
			<div class="absolute top-[40%] -right-[10%] w-[35%] h-[50%] rounded-full bg-nord14 opacity-[0.08] blur-[120px]"></div>
			<!-- Naranja (nord12) abajo a la izquierda -->
			<div class="absolute -bottom-[20%] left-[10%] w-[50%] h-[40%] rounded-full bg-nord12 opacity-[0.10] blur-[120px]"></div>
		</div>

		<!-- Curved SVG Wave overlay at the very top for depth (Simulating Nordtheme's curve) -->
		<div class="pointer-events-none absolute top-0 left-0 w-full overflow-hidden leading-[0] z-[-1]">
			<svg class="relative block w-full h-[300px]" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 120" preserveAspectRatio="none">
				<path d="M321.39,56.44c58-10.79,114.16-30.13,172-41.86,82.39-16.72,168.19-17.73,250.45-.39C823.78,31,906.67,72,985.66,92.83c70.05,18.48,146.53,26.09,214.34,3V0H0V27.35A600.21,600.21,0,0,0,321.39,56.44Z" class="fill-nord1/40"></path>
			</svg>
		</div>

		<slot />
	</body>
</html>
