---
import Layout from "../layouts/Layout.astro";
---

<Layout title="hrod.dev | Inicia en DevOps y Linux">
	<!-- Navbar Fijo -->
	<nav class="fixed top-0 inset-x-0 z-50 bg-nord0/95 border-b border-nord2/50">
		<div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
			<a href="/" class="flex items-center gap-2 group transition-opacity hover:opacity-80">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 60 60" fill="none" class="w-7 h-7">
					<defs>
						<linearGradient id="aurora-nav" x1="0%" y1="0%" x2="100%" y2="100%">
							<stop offset="0%" stop-color="#bf616a"/>
							<stop offset="50%" stop-color="#d08770"/>
							<stop offset="100%" stop-color="#ebcb8b"/>
						</linearGradient>
					</defs>
					<path d="M8 12 L28 30 L8 48" stroke="url(#aurora-nav)" stroke-width="7" stroke-linecap="round" stroke-linejoin="round"/>
					<line x1="32" y1="48" x2="52" y2="48" stroke="url(#aurora-nav)" stroke-width="7" stroke-linecap="round"/>
				</svg>
				<span class="text-lg tracking-tight"><span class="text-nord6 font-black">hrod</span><span class="text-nord4 font-light">.dev</span></span>
			</a>
			<div class="flex items-center gap-6">
				<a href="https://blog.hrod.dev" class="text-nord4 hover:text-nord6 text-sm font-medium transition-colors">Blog</a>
				<a href="#rutas" class="text-nord4 hover:text-nord6 text-sm font-medium transition-colors">Rutas</a>
				<div class="flex items-center gap-4 ml-2 border-l border-nord3 pl-4">
          <a href="https://github.com/hroddev/hrod-landing" target="_blank" aria-label="GitHub"
						class="text-nord4 hover:text-nord8 transition-colors">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"></path></svg>
					</a>
					<a href="https://linkedin.com/in/hroddev" target="_blank" aria-label="LinkedIn"
						class="text-nord4 hover:text-nord9 transition-colors">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
					</a>
				</div>
			</div>
		</div>
	</nav>

	<main class="max-w-6xl mx-auto px-6 pt-28">
		<!-- Hero: Split Screen -->
		<header class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[70vh] py-16 animate-fade-in">
			<!-- Columna Izquierda: Texto -->
			<div class="relative z-10">
				<div
					class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-nord1 border border-nord3 text-xs font-medium text-nord4 mb-8 shadow-sm"
				>
					<span class="w-2 h-2 rounded-full bg-nord14 animate-pulse"></span>
					Cloud & DevOps Engineer
				</div>

				<h1
					class="text-4xl sm:text-5xl lg:text-[3.5rem] font-bold tracking-tight mb-6 text-nord6 leading-[1.1] selection:bg-nord3"
				>
					Insights, Tutoriales<br />
					y código para el<br />
					<span
						class="bg-gradient-to-r from-nord11 via-nord12 to-nord13 bg-clip-text text-transparent animate-gradient-x"
					>
						Ingeniero moderno.
					</span>
				</h1>

				<p
					class="text-nord4 max-w-lg text-base lg:text-lg leading-relaxed mb-10 selection:bg-nord3 font-light"
				>
					Guías prácticas, recursos y tutoriales paso a paso para
					dominar Linux, automatizar infraestructura y desplegar en la nube
					como un profesional.
				</p>

				<div class="flex flex-col sm:flex-row gap-4 font-sans">
					<a
						href="https://blog.hrod.dev"
						class="group inline-flex items-center justify-center gap-2 bg-gradient-to-r from-nord11 to-nord12 hover:from-nord12 hover:to-nord11 text-nord6 px-7 py-3 rounded-xl font-bold text-sm transition-all duration-300 shadow-xl shadow-nord11/20 hover:scale-105"
					>
						<span>Leer el Blog</span>
						<svg
							class="w-4 h-4 group-hover:translate-x-1 transition-transform"
							fill="none"
							viewBox="0 0 24 24"
							stroke="currentColor"
						>
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
						</svg>
					</a>
					<a
						href="#rutas"
						class="inline-flex items-center justify-center gap-2 bg-nord1 hover:bg-nord2 border border-nord3 text-nord4 hover:text-nord6 px-7 py-3 rounded-xl font-medium text-sm transition-all duration-300"
					>
						Rutas de Aprendizaje
					</a>
				</div>
			</div>

			<!-- Columna Derecha: Terminal -->
			<div class="relative z-10">
				<div class="bg-nord1 rounded-2xl border border-nord2 shadow-2xl shadow-black/30 overflow-hidden">
					<!-- Barra de título -->
					<div class="flex items-center gap-2 px-4 py-3 bg-nord0 border-b border-nord2">
						<div class="w-3 h-3 rounded-full bg-nord11"></div>
						<div class="w-3 h-3 rounded-full bg-nord13"></div>
						<div class="w-3 h-3 rounded-full bg-nord14"></div>
						<span class="ml-3 text-nord4 text-xs font-mono opacity-60">hrod@devops: ~</span>
					</div>
					<!-- Contenido del terminal -->
					<div class="p-5 font-mono text-sm leading-relaxed space-y-1">
						<p class="terminal-line">
							<span class="text-nord14">hrod</span><span class="text-nord4">@</span><span class="text-nord8">devops</span><span class="text-nord4">:~$</span>
							<span class="text-nord6 ml-2">whoami</span>
						</p>
						<p class="terminal-line text-nord4 pl-0">
							Hector Rodriguez — Cloud & DevOps Engineer
						</p>
						<p class="terminal-line mt-3">
							<span class="text-nord14">hrod</span><span class="text-nord4">@</span><span class="text-nord8">devops</span><span class="text-nord4">:~$</span>
							<span class="text-nord6 ml-2">cat skills.yml</span>
						</p>
						<p class="terminal-line text-nord9 pl-0">cloud:</p>
						<p class="terminal-line text-nord4 pl-4">
							- <span class="text-nord13">Azure</span> · <span class="text-nord13">Terraform</span> · <span class="text-nord13">Kubernetes</span>
						</p>
						<p class="terminal-line text-nord9 pl-0">tools:</p>
						<p class="terminal-line text-nord4 pl-4">
							- <span class="text-nord14">Linux</span> · <span class="text-nord14">Docker</span> · <span class="text-nord14">Git</span> · <span class="text-nord14">CI/CD</span>
						</p>
						<p class="terminal-line mt-3">
							<span class="text-nord14">hrod</span><span class="text-nord4">@</span><span class="text-nord8">devops</span><span class="text-nord4">:~$</span>
							<span class="text-nord6 ml-2">cat latest_post.md</span>
						</p>
						<p class="terminal-line text-nord8 pl-0 font-bold">
							# Helix Cloud: Despliegue Inicial
						</p>
						<p class="terminal-line mt-2">
							<span class="text-nord14">hrod</span><span class="text-nord4">@</span><span class="text-nord8">devops</span><span class="text-nord4">:~$</span>
							<span class="inline-block w-2 h-4 bg-nord6 ml-2 animate-blink"></span>
						</p>
					</div>
				</div>
				<!-- Glow effect behind terminal -->
				<div class="absolute -inset-4 bg-gradient-to-br from-nord15/10 via-transparent to-nord8/10 rounded-3xl blur-xl -z-10"></div>
			</div>
		</header>

		<!-- Rutas de Aprendizaje / Pilares con colores de Aurora -->
		<section class="relative z-10 py-24" id="rutas">
			<div class="mb-8">
				<h2 class="text-2xl font-semibold text-nord6 mb-2">
					¿Por dónde empezar?
				</h2>
				<p class="text-nord4 text-sm">
					Explora las áreas clave para dominar la infraestructura
					moderna.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
				<!-- Card 1: Fundamentos (Linux) -> Verde Aurora -->
				<div
					class="p-6 rounded-2xl border border-nord2 bg-nord1/60 backdrop-blur-md hover:border-nord14/50 hover:bg-nord1/80 transition-all duration-300 group shadow-sm"
				>
					<div
						class="w-12 h-12 rounded-xl bg-nord14/10 flex items-center justify-center mb-5 text-nord14 group-hover:scale-110 transition-transform"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
					</div>
					<h3 class="text-nord6 font-medium text-lg mb-2">
						El arte de Linux
					</h3>
					<p class="text-nord4 text-sm leading-relaxed">
						Domina la terminal paso a paso. Desde navegar por
						carpetas hasta crear tus propios *scripts* mágicos en
						Bash.
					</p>
				</div>

				<!-- Card 2: Cloud -> Naranja Aurora -->
				<div
					class="p-6 rounded-2xl border border-nord2 bg-nord1/60 backdrop-blur-md hover:border-nord12 hover:bg-nord1/80 transition-all duration-500 group shadow-lg shadow-nord12/5 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-xl bg-nord12/20 flex items-center justify-center mb-5 text-nord12 group-hover:scale-110 group-hover:bg-nord12 group-hover:text-nord0 transition-all duration-300 shadow-lg shadow-nord12/20"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"></path></svg>
					</div>
					<h3 class="text-nord6 font-bold text-lg mb-2 group-hover:text-nord12 transition-colors">
						Construye la Nube
					</h3>
					<p class="text-nord4 text-sm leading-relaxed">
						Descubre cómo los gigantes despliegan servidores con
						código. Aprenderás Terraform, conceptos de redes y
						Azure.
					</p>
				</div>

				<!-- Card 3: Seguridad -> Morado Aurora -->
				<div
					class="p-6 rounded-2xl border border-nord2 bg-nord1/60 backdrop-blur-md hover:border-nord15/50 hover:bg-nord1/80 transition-all duration-300 group shadow-sm"
				>
					<div
						class="w-12 h-12 rounded-xl bg-nord15/10 flex items-center justify-center mb-5 text-nord15 group-hover:scale-110 transition-transform"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
					</div>
					<h3 class="text-nord6 font-medium text-lg mb-2">
						Seguridad (DevSecOps)
					</h3>
					<p class="text-nord4 text-sm leading-relaxed">
						Protege tus aplicaciones. Te enseñaré a ocultar
						contraseñas, gestionar permisos y desarrollar hábitos
						seguros.
					</p>
				</div>

				<!-- Card 4: AI -> Rojo Aurora -->
				<div
					class="p-6 rounded-2xl border border-nord2 bg-nord1/60 backdrop-blur-md hover:border-nord11 hover:bg-nord1/80 transition-all duration-500 group shadow-lg shadow-nord11/5 hover:-translate-y-1"
				>
					<div
						class="w-12 h-12 rounded-xl bg-nord11/20 flex items-center justify-center mb-5 text-nord11 group-hover:scale-110 group-hover:bg-nord11 group-hover:text-nord6 transition-all duration-300 shadow-lg shadow-nord11/20"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
					</div>
					<h3 class="text-nord6 font-bold text-lg mb-2 group-hover:text-nord11 transition-colors">
						Automatización Inteligente
					</h3>
					<p class="text-nord4 text-sm leading-relaxed">
						Usa la Inteligencia Artificial a tu favor. Integra
						agentes que lean logs, diagnostiquen errores y optimicen
						tu tiempo.
					</p>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer
			class="py-12 flex flex-col items-center justify-center gap-4 text-center border-t border-nord2/50 relative z-10 w-full"
		>
			<div class="flex items-center gap-6 text-nord4 mb-2">
				<a href="https://github.com/hroddev" target="_blank" aria-label="GitHub"
					class="hover:text-nord8 transition-colors duration-300 hover:scale-110">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"></path></svg>
				</a>
				<a href="https://linkedin.com/in/hroddev" target="_blank" aria-label="LinkedIn"
					class="hover:text-nord9 transition-colors duration-300 hover:scale-110">
					<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" clip-rule="evenodd" d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg>
				</a>
				<a href="https://x.com/hroddev" target="_blank" aria-label="X/Twitter"
					class="hover:text-nord15 transition-colors duration-300 hover:scale-110">
					<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.005 4.15H5.059z"></path></svg>
				</a>
			</div>

			<div class="text-nord4 text-sm font-medium mb-1">
				<span class="font-bold text-nord6">Hector Rodriguez R.</span>
				<span class="text-nord3 mx-1.5">•</span>
				<span class="font-mono text-xs text-nord8/80">Cloud & DevOps Engineer</span>
			</div>

			<div class="text-nord4 text-xs sm:text-sm mt-3 opacity-90">
				Diseñado en
				<a href="https://astro.build" target="_blank" rel="noopener noreferrer"
					class="text-nord12 hover:text-nord13 underline decoration-nord3 underline-offset-4 transition-colors font-medium">Astro</a>
				<span class="text-nord3 mx-2">|</span>
				<span>Me encanta <a href="https://www.nordtheme.com/" target="_blank" rel="noopener noreferrer"
					class="text-nord15 hover:text-nord14 underline decoration-nord15/50 underline-offset-4 transition-colors font-bold px-1">Nord Theme</a></span>
			</div>
		</footer>
	</main>
</Layout>
